#include <stdlib.h>
#include <stdio.h>
#include <string.h>

#define MAX_BASKETS 3
#define MAX_ITEMS   50

int basketStack[MAX_BASKETS] = {30, 20, 10};
int top = MAX_BASKETS - 1;

typedef struct {
    char name[20];
    float price;
    int quantity;
} Item;

Item *stock = NULL;
int stockCount = 0;

Item basket[MAX_ITEMS];
int basketCount = 0;

void initStock() {
    stockCount = 9;
    stock = (Item *)malloc(stockCount * sizeof(Item));

    strcpy(stock[0].name, "Apple");   stock[0].price = 5.0;   stock[0].quantity = 10;
    strcpy(stock[1].name, "Banana");  stock[1].price = 2.0;   stock[1].quantity = 20;
    strcpy(stock[2].name, "Milk");    stock[2].price = 30.0;  stock[2].quantity = 15;
    strcpy(stock[3].name, "Bread");   stock[3].price = 25.0;  stock[3].quantity = 12;
    strcpy(stock[4].name, "Eggs");    stock[4].price = 6.0;   stock[4].quantity = 30;
    strcpy(stock[5].name, "Rice");    stock[5].price = 40.0;  stock[5].quantity = 50;
    strcpy(stock[6].name, "Chicken"); stock[6].price = 120.0; stock[6].quantity = 20;
    strcpy(stock[7].name, "Coffee");  stock[7].price = 80.0;  stock[7].quantity = 25;
    strcpy(stock[8].name, "Sugar");   stock[8].price = 45.0;  stock[8].quantity = 40;
}

void menu () {
    printf("\n-----GROCERY SHOP----\n\n");
    printf("1. Take a basket\n");
    printf("2. Return basket\n");
    printf("3. View Inventory\n");
    printf("4. Buy Item\n");
    printf("5. View Basket\n");
    printf("6. Exit\n\n");
    printf("Input your choice: ");
}

void back() {
    printf("\nReturning to menu...\n");
    menu();
}

void pushBasket(int basketNum) {
    if (basketNum <= 0) {
        printf("Invalid basket number.\n");
    } else if(top == MAX_BASKETS - 1) {
        printf("Baskets are full\n");
    } else {
        top++;
        basketStack[top] = basketNum;
        printf("Basket #%d returned\n", basketNum);
    }
    back();
}

void popBasket() {
    if (top == -1) {
        printf("No baskets available\n");
    } else {
        int basket = basketStack[top];
        printf("You grabbed basket #%d\n", basket);
        top--;
    }
    back();
}

void viewStock() {
    printf("\n-----INVENTORY-----\n\n");
    for (int i = 0; i < stockCount; i++) {
        printf("%d. %s - Price: %.2f - Quantity: %d\n",
               i+1, stock[i].name, stock[i].price, stock[i].quantity);
    }
    back();
}

void buyItem() {
    if (top == MAX_BASKETS - 1) {
        printf("You must take a basket before buying.\n");
        back();
        return;
    }

    char name[20];
    int qty;

    printf("Enter item name: ");
    scanf("%s", name);
    printf("Enter quantity: ");
    if (scanf("%d", &qty) != 1 || qty <= 0) {
        printf("Invalid quantity.\n");
        back();
        return;
    }

    for (int i = 0; i < stockCount; i++) {
        if (strcmp(stock[i].name, name) == 0) {
            if (stock[i].quantity >= qty) {
                stock[i].quantity -= qty;
                float total = stock[i].price * qty;
                printf("You bought %d %s(s) for %.2f\n", qty, name, total);

                strcpy(basket[basketCount].name, stock[i].name);
                basket[basketCount].price = stock[i].price;
                basket[basketCount].quantity = qty;
                basketCount++;

                if (stock[i].quantity == 0) {
                    printf("%s is now out of stock.\n", name);
                }
            } else {
                printf("Not enough stock for %s. Available: %d\n", name, stock[i].quantity);
            }
            back();
            return;
        }
    }
    printf("Item %s not found.\n", name);
    back();
}

void viewBasket() {
    printf("\n-----YOUR BASKET-----\n\n");
    if (basketCount == 0) {
        printf("Your basket is empty.\n");
        back();
        return;
    }

    for (int i = 0; i < basketCount; i++) {
        printf("%d. %s - Price: %.2f - Quantity: %d\n",
               i+1, basket[i].name, basket[i].price, basket[i].quantity);
    }

    int choice;
    printf("\nEnter item number to remove (0 to cancel): ");
    if (scanf("%d", &choice) != 1) {
        while(getchar()!='\n');
        printf("Invalid input.\n");
        back();
        return;
    }

    if (choice > 0 && choice <= basketCount) {
        int idx = choice - 1;
        for (int i = 0; i < stockCount; i++) {
            if (strcmp(stock[i].name, basket[idx].name) == 0) {
                stock[i].quantity += basket[idx].quantity;
            }
        }
        printf("Removed %s from basket and returned to stock.\n", basket[idx].name);

        for (int j = idx; j < basketCount - 1; j++) {
            basket[j] = basket[j+1];
        }
        basketCount--;
    } else if (choice != 0) {
        printf("Invalid choice.\n");
    }
    back();
}

void menuChoice() {
    int choice;
    int bNum;
    while (scanf("%d", &choice)) {
        switch (choice) {
            case 1:
                popBasket();
                break;
            case 2:
                printf("Enter basket number to return: ");
                if (scanf("%d", &bNum) != 1) {
                    while(getchar()!='\n');
                    printf("Invalid input.\n");
                } else {
                    pushBasket(bNum);
                }
                break;
            case 3:
                viewStock();
                break;
            case 4:
                buyItem();
                break;
            case 5:
                viewBasket();
                break;
            case 6:
                printf("\n-----GOODBYE-----\n");
                printf("Thank you for shopping!\n");
                free(stock);
                return;
            default:
                printf("Invalid choice.\n");
                back();
        }
    }
}

int main () {
    initStock();
    menu();
    menuChoice();
    return 0;
}
