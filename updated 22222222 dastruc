#include <stdlib.h>
#include <stdio.h>
#include <string.h>

#define MAX_BASKETS 5
#define MAX_ITEMS   50

int basketStack[MAX_BASKETS] = {50, 40, 30, 20, 10};
int top = MAX_BASKETS - 1;

typedef struct {
    char name[20];
    float price;
    int quantity;
} Item;

Item *stock = NULL;
int stockCount = 0;

Item basket[MAX_ITEMS];
int basketCount = 0;

void setupStock() {
    stockCount = 9;
    stock = (Item *)malloc(stockCount * sizeof(Item));

    strcpy(stock[0].name, "Apple");   stock[0].price = 5.0;   stock[0].quantity = 10;
    strcpy(stock[1].name, "Banana");  stock[1].price = 2.0;   stock[1].quantity = 20;
    strcpy(stock[2].name, "Milk");    stock[2].price = 30.0;  stock[2].quantity = 15;
    strcpy(stock[3].name, "Bread");   stock[3].price = 25.0;  stock[3].quantity = 12;
    strcpy(stock[4].name, "Eggs");    stock[4].price = 6.0;   stock[4].quantity = 30;
    strcpy(stock[5].name, "Rice");    stock[5].price = 40.0;  stock[5].quantity = 50;
    strcpy(stock[6].name, "Chicken"); stock[6].price = 120.0; stock[6].quantity = 20;
    strcpy(stock[7].name, "Coffee");  stock[7].price = 80.0;  stock[7].quantity = 25;
    strcpy(stock[8].name, "Sugar");   stock[8].price = 45.0;  stock[8].quantity = 40;
}

void showMenu() {
    printf("\n=== Grocery Shop ===\n\n");
    printf("1. Grab a basket\n");
    printf("2. Return a basket\n");
    printf("3. See the items in stock\n");
    printf("4. Buy something\n");
    printf("5. Check your basket\n");
    printf("6. Leave shop\n\n");
    printf("Pick an option: ");
}

void goBack() {
    printf("\nBack to menu...\n");
    showMenu();
}

void returnBasket(int basketNum) {
    if (basketNum <= 0) {
        printf("That basket number doesn’t make sense.\n");
    } else if(top == MAX_BASKETS - 1) {
        printf("All baskets are already here.\n");
    } else {
        for (int i = 0; i < basketCount; i++) {
            Item *b = &basket[i];
            for (int j = 0; j < stockCount; j++) {
                Item *p = &stock[j];
                if (strcmp(p->name, b->name) == 0) {
                    p->quantity += b->quantity;
                }
            }
        }
        basketCount = 0;
        top++;
        basketStack[top] = basketNum;
        printf("Basket #%d and the items are returned.\n", basketNum);
    }
    goBack();
}

void grabBasket() {
    if (top == -1) {
        printf("No baskets left.\n");
    } else {
        int basket = basketStack[top];
        printf("You grabbed basket #%d.\n", basket);
        top--;
    }
    goBack();
}

void showStock() {
    printf("\n--- Stock ---\n\n");
    for (int i = 0; i < stockCount; i++) {
        Item *p = &stock[i];
        printf("%d. %s - %.2f each - %d left\n",
               i+1, p->name, p->price, p->quantity);
    }
    goBack();
}

void buyStuff() {
    if (top == MAX_BASKETS - 1) {
        printf("Grab a basket first\n");
        goBack();
        return;
    }

    char itemName[20];
    int qty;

    printf("What do you want to buy? ");
    scanf("%s", itemName);
    printf("How many? ");
    if (scanf("%d", &qty) != 1 || qty <= 0) {
        printf("Not enough items in the stock.\n");
        goBack();
        return;
    }

    for (int i = 0; i < stockCount; i++) {
        Item *p = &stock[i];
        if (strcmp(p->name, itemName) == 0) {
            if (p->quantity >= qty) {
                p->quantity -= qty;
                float total = p->price * qty;
                printf("%d %s added to your basket. Cost: %.2f\n", qty, itemName, total);

                Item *b = &basket[basketCount];
                strcpy(b->name, p->name);
                b->price = p->price;
                b->quantity = qty;
                basketCount++;

                if (p->quantity == 0) {
                    printf("%s is now sold out.\n", itemName);
                }
            } else {
                printf("Only %d left in stock.\n", p->quantity);
            }
            goBack();
            return;
        }
    }
    printf("You didn't get %s.\n", itemName);
    goBack();
}

void checkBasket() {
    printf("\n--- Your Basket ---\n\n");
    if (basketCount == 0) {
        printf("There are no items in your basket.\n");
        goBack();
        return;
    }

    for (int i = 0; i < basketCount; i++) {
        Item *b = &basket[i];
        printf("%d. %s - %.2f each - %d pcs\n",
               i+1, b->name, b->price, b->quantity);
    }

    int choice;
    printf("\nEnter number of items to return (0 to cancel): ");
    if (scanf("%d", &choice) != 1) {
        while(getchar()!='\n');
        printf("Invalid input.\n");
        goBack();
        return;
    }

    if (choice > 0 && choice <= basketCount) {
        int idx = choice - 1;
        Item *b = &basket[idx];
        for (int i = 0; i < stockCount; i++) {
            Item *p = &stock[i];
            if (strcmp(p->name, b->name) == 0) {
                p->quantity += b->quantity;
            }
        }
        printf("%s removed from basket.\n", b->name);

        for (int j = idx; j < basketCount - 1; j++) {
            basket[j] = basket[j+1];
        }
        basketCount--;
    } else if (choice != 0) {
        printf("Invalid choice.\n");
    }
    goBack();
}

void pickChoice() {
    int choice;
    int bNum;
    while (scanf("%d", &choice)) {
        switch (choice) {
            case 1:
                grabBasket();
                break;
            case 2:
                printf("Enter basket number to return: ");
                if (scanf("%d", &bNum) != 1) {
                    while(getchar()!='\n');
                    printf("Invalid input.\n");
                } else {
                    returnBasket(bNum);
                }
                break;
            case 3:
                showStock();
                break;
            case 4:
                buyStuff();
                break;
            case 5:
                checkBasket();
                break;
            case 6:
                printf("\nThanks for shopping!\n");
                free(stock);
                return;
            default:
                printf("Invalid option.\n");
                goBack();
        }
    }
}

int main () {
    setupStock();
    showMenu();
    pickChoice();
    return 0;
}
