#include <stdlib.h>
#include <stdio.h>

#define MAX_ITEMS 50
#define MAX_BASKETS 3

int basketStack[MAX_BASKETS] = {30, 20, 10};
int top = MAX_BASKETS - 1;

char items[MAX_ITEMS][20];
int itemCount = 0;


void menu () {
    printf("-----GROCERY SHOP----\n\n");
    printf("1. Take a basket\n");
    printf("2. Return basket\n");
    printf("3. Add Item\n");
    printf("4. Inventory\n");
    printf("5. Exit\n\n");
    printf("Input your choice: ");
}

void pushBasket(int basketNum)
{
    if(top == MAX_BASKETS - 1)
    {
        printf("Baskets are full\n");
    }
    else
    {
        top++;
        basketStack[top] = basketNum;
        printf("Basket #%d is returned", basketNum);
    }
}
void popBasket()
{
    if (top == -1) {
        printf("No baskets available\n");
    }
    else 
    {
        int basket = basketStack[top];
        printf("You grabbed basket #%d\n", basket);
        top--;
    }
}
void AddItem()
{  
      system("clear");
      printf("Put Items\n");
      scanf("%s", items[itemCount]);
      itemCount++;
}
void back (){
 printf("1. Back\n");
    printf("input choice: ");
    int choiceTwo;
    if(scanf("%d", &choiceTwo) == 1)
    {
      menu();
    }
}
void menuChoice()
{
int choice;
int bNum;
while (scanf("%d", &choice))
{
switch (choice)
{
case 1:
    system("clear");
    popBasket();
    back();
    break;
    
case 2:
    system("clear");
    printf("Enter basket number to return: ");
    scanf("%d", &bNum);
    pushBasket(bNum);
    back();
    break;

case 3:
     system("clear");
     AddItem();
     back();
  
     break;
 
case 4:
     system("clear");
     printf("\n-----INVENTORY-----\n\n");
     for (int i = 0; i < itemCount; i++) {
     printf(" %s\n", items[i]);
     }
     back();
     break;

case 5:
    printf("\n-----GOODBYE-----\n");
     printf("\nThank you for shopping!\n");
     return;
     break;
} 
}
} 
int main () {
menu();
menuChoice();
return 0;
}