#include <stdlib.h>
#include <stdio.h>

#define MAX_ITEMS 50
#define MAX_BASKETS 3
#define MAX_CUSTOMERS 3

int basketStack[MAX_BASKETS] = {30, 20, 10};
int top = MAX_BASKETS - 1;

char items[MAX_ITEMS][20];
int itemCount = 0;

char customerQueue[MAX_CUSTOMERS][20];
int front = 0;
int rear = 0;


void menu () {
    printf("-----GROCERY SHOP----\n\n");
    printf("1. Take a basket\n");
    printf("2. Return basket\n");
    printf("3. Add Item\n");
    printf("4. Inventory\n");
    printf("5. Next Customer\n");
    printf("6. Remove Customer\n");
    printf("7. Exit\n\n");
    printf("Input your choice: ");
}

void enqueue()
{
    if (rear == MAX_CUSTOMERS)
    {
    printf("The line is full\n");
    }
    else
    {
        printf("Enter customer name: ");
        scanf("%s", &customerQueue[rear]);
        printf("%s joined the queue\n", customerQueue[rear]);
        rear++;
    }
}

void dequeue()
{
    if (front == MAX_CUSTOMERS - 1)
    {
        printf("The line is empty\n");
    }
    else
    {
        printf("Who will you remove from the queue: ");
        scanf("Customer %s left the line", &customerQueue[front]);
        front--;
    }
}

void pushBasket(int basketNum)
{
    if(top == MAX_BASKETS - 1)
    {
        printf("Baskets are full\n");
    }
    else
    {
        top++;
        basketStack[top] = basketNum;
        printf("Basket #%d is returned", basketNum);
    }
}
void popBasket()
{
    if (top == -1) {
        printf("No baskets available");
    }
    else 
    {
        int basket = basketStack[top];
        printf("You grabbed basket #%d\n", basket);
        top--;
    }
}
void AddItem()
{  
      system("clear");
      printf("Put Items\n");
      scanf("%s", items);
}
